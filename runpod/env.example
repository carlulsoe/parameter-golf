PGOLF_REPO_URL=git@github.com:your-org/parameter-golf.git
PGOLF_REPO_DIR=/workspace/parameter-golf
PGOLF_BRANCH=runpod-autoresearch
PGOLF_DATA_ROOT=/mnt/persistent
# Or set these explicitly instead of PGOLF_DATA_ROOT:
# DATA_PATH=/mnt/persistent/datasets/fineweb10B_sp1024
# TOKENIZER_PATH=/mnt/persistent/tokenizers/fineweb_1024_bpe.model
PGOLF_PYTHON=python3
PGOLF_TORCHRUN=torchrun
PGOLF_NPROC_PER_NODE=1
PGOLF_STATE_DIR=/workspace/parameter-golf/runpod_state
PGOLF_LOG_DIR=/workspace/parameter-golf/logs
