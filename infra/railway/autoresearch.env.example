# Railway controller container

# Persistent experiment repo bootstrap on the Railway volume
PGOLF_REPO_URL=git@github.com:your-org/parameter-golf.git
PGOLF_REPO_BRANCH=main
PGOLF_RUNTIME_ROOT=/var/lib/parameter-golf
PGOLF_REPO_DIR=/var/lib/parameter-golf/repo
PGOLF_FETCH_ON_BOOT=0

# Codex authentication
# The Codex docs recommend API key auth for programmatic CLI workflows.
OPENAI_API_KEY=sk-...

# Optional SSH materialization inside the container.
# Base64 variants are easier to manage from a local env file.
SSH_PRIVATE_KEY_BASE64=
SSH_KNOWN_HOSTS_BASE64=

# Controller runtime
CONTROLLER_ARGS=--forever
PROPOSER_MODEL=gpt-5.4
PRE_REVIEW_MODEL=gpt-5.4
POST_REVIEW_MODEL=gpt-5.4

# GPU worker contract
REMOTE_HOST=root@runpod-worker
REMOTE_PORT=22
REMOTE_REPO_DIR=/workspace/parameter-golf
REMOTE_BRANCH=runpod-autoresearch
REMOTE_TORCHRUN=/workspace/parameter-golf/.venv/bin/torchrun
REMOTE_IDENTITY=/root/.ssh/id_ed25519

# Experiment defaults
DATA_PATH=/workspace/network-volume/datasets/fineweb10B_sp1024
TOKENIZER_PATH=/workspace/network-volume/tokenizers/fineweb_1024_bpe.model
VOCAB_SIZE=1024
ITERATIONS=20000
MAX_WALLCLOCK_SECONDS=600
VAL_LOSS_EVERY=0
NPROC_PER_NODE=1
MAX_PRE_REVIEW_ROUNDS=3
PREP_QUEUE_DEPTH=1
BASE_EXTRA_ENV=TRAIN_BATCH_TOKENS=524288 VAL_BATCH_SIZE=524288 TRAIN_SEQ_LEN=1024 EVAL_SEQ_LEN=1024

# Trace and logs inside the persistent experiment repo checkout
TRACE_ROOT=controller_state/autoresearch
RESULTS_FILE=results.tsv
REVIEWS_FILE=reviews.tsv
HARNESS_LOG=logs/autoresearch_railway.log
